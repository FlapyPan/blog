---
import { profileConfig } from '../config'
import { url } from '../utils/url-utils'
---

<div class="card-base max-w-[var(--page-width)] min-h-[4.5rem] rounded-b-none mx-auto flex items-center px-6">
    <div class="transition text-50 text-sm">
        © 2024 {profileConfig.name} /
        <a id="cf-link" class="link text-[var(--primary)] font-medium" target="_blank" href="https://flapypan.top">CloudFlare 主站</a> /
        <a id="vercel-link" class="link text-[var(--primary)] font-medium" target="_blank" href="https://vercel.flapypan.top">Vercel 镜像站</a> /
        <a class="link text-[var(--primary)] font-medium" target="_blank" href={url('rss.xml')}>RSS</a> /
        <a class="link text-[var(--primary)] font-medium" target="_blank" href={url('sitemap-index.xml')}>Sitemap</a>
        <br>
        Powered by
        <a class="link text-[var(--primary)] font-medium" target="_blank" href="https://astro.build">Astro</a> &
        <a class="link text-[var(--primary)] font-medium" href="https://github.com/saicaca/fuwari">Fuwari</a>
        { profileConfig.icpCode
            ? <> / <a class="link text-[var(--primary)] font-medium" target="_blank" href={profileConfig.icpLink}>{profileConfig.icpCode}</a></>
            : <></>
        }
    </div>
</div>
